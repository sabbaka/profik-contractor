default_platform(:ios)

# Build the App Store Connect API key from environment variables.
# Required env vars:
#   ASC_KEY_ID        — the Key ID from App Store Connect
#   ASC_ISSUER_ID     — the Issuer ID from App Store Connect
#   ASC_KEY_FILEPATH  — absolute path to the downloaded .p8 file
#                       (e.g. ~/.appstoreconnect/private_keys/AuthKey_XXXX.p8)
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: File.expand_path(ENV.fetch("ASC_KEY_FILEPATH")),
    duration: 1200,
    in_house: false
  )
end

platform :ios do
  desc "Push only metadata (no binary, no screenshots) to App Store Connect"
  lane :push_metadata do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: false,
      force: true,
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

  desc "Push metadata + screenshots (no binary)"
  lane :push_metadata_and_screenshots do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_app_version_update: false,
      force: true,
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

  desc "Submit the current version for App Store Review (no binary upload)"
  lane :submit_for_review do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        export_compliance_encryption_updated: false,
        content_rights_contains_third_party_content: false,
        content_rights_has_rights: true
      }
    )
  end
end
